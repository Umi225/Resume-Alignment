# ============================================
# AI Provider 配置
# ============================================

# Provider 类型：openai | kimi | custom
# - openai: 使用 OpenAI 官方 API
# - kimi: 使用 Moonshot (Kimi) API
# - custom: 使用任意 OpenAI-compatible API（需同时配置 AI_API_URL）
AI_PROVIDER=kimi

# API 密钥（必填）
# - OpenAI: 从 https://platform.openai.com/api-keys 获取
# - Kimi: 从 https://platform.moonshot.cn/ 获取
AI_API_KEY=sk-your-api-key-here

# API 端点（custom 模式下必填；使用预设时可不填）
# - OpenAI 默认: https://api.openai.com/v1/chat/completions
# - Kimi 默认: https://api.moonshot.cn/v1/chat/completions
# AI_API_URL=https://api.moonshot.cn/v1/chat/completions

# 模型名称（必填；使用预设时有默认值）
# - OpenAI 默认: gpt-4o
# - Kimi 默认: moonshot-v1-8k
# AI_MODEL=moonshot-v1-8k

# 可选参数
# AI_TEMPERATURE=0.3
# AI_MAX_TOKENS=4096
